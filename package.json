{
  "name": "ae-script-launcher",
  "version": "1.0.0",
  "description": "After Effects Script Launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.yourname.ae-launcher",
    "productName": "AE Script Launcher",
    "icon": "assets/icon",
    "files": ["src/**/*", "assets/**/*"],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
